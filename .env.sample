# Foundry project endpoint (required)
AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Model deployment (optional, defaults to gpt-4.1)
MODEL_DEPLOYMENT_NAME=gpt-4.1

# Azure target defaults
DEFAULT_LOCATION=australiaeast
DEFAULT_SUBSCRIPTION_ID=

# Behaviour
CLEANUP_ON_COMPLETE=true
TEST_RG_PREFIX=rg-avm-test-

# Runtime mode (set to true when hosted on Foundry)
FOUNDRY_HOSTED=false

# Multi-agent mode (set to true for hub-and-spoke agent topology)
MULTI_AGENT=false

# Security / module allowlist
# Comma-separated GitHub orgs whose modules are auto-approved
TRUSTED_ORGS=Azure,kewalaka
# Comma-separated Terraform registry namespaces that are auto-approved
TRUSTED_REGISTRY=Azure/

# MCP connections (Foundry-hosted mode only)
GITHUB_MCP_CONNECTION_ID=
AZURE_MCP_CONNECTION_ID=
EVA_MCP_SERVER_URL=
