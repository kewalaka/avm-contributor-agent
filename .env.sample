# ── Foundry (required) ─────────────────────────────────────────────────────────
# Azure AI Foundry project endpoint
AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Model deployment name (defaults to gpt-4.1 if not set)
MODEL_DEPLOYMENT_NAME=gpt-4.1

# ── CI Dispatch (required for dev mode) ───────────────────────────────────────
# Fine-grained PAT scoped to kewalaka/avm-contributions only.
# Required permissions: Actions (Read/Write), Contents (Read), Metadata (Read)
# Expiry: 90 days recommended; rotate via GitHub Settings > Developer settings > PATs
#
# Setup:
#   1. https://github.com/settings/personal-access-tokens/new
#   2. Resource owner: your account; Repository access: kewalaka/avm-contributions
#   3. Permissions: Actions RW, Contents R, Metadata R
#   4. Paste the generated token below
AGENT_DISPATCH_TOKEN=github_pat_REPLACE_ME

# ── Runtime mode ──────────────────────────────────────────────────────────────
# Set to true when the agent process is hosted on Foundry (uses connection auth)
FOUNDRY_HOSTED=false

# ── MCP connections (Foundry-hosted mode only) ─────────────────────────────────
# These are Foundry project connection NAMES (not PATs or tokens).
# Create connections in: Foundry project → Settings → Connected Resources
#
# GITHUB_MCP_CONNECTION_ID: GitHub connection name → enables GitHub MCP server
#   (issues, PRs, repo file reads via https://api.githubcopilot.com/mcp)
#   When set, specialist agents can read GitHub resources server-side without gh CLI.
#
# AZURE_MCP_CONNECTION_ID: Azure connection name → enables Azure MCP server
#   (resource queries via https://mcp.azure.com)
#
# EVA_MCP_SERVER_URL: Full URL to EVA/AzAPI MCP server
#   (AzAPI resource type discovery; typically an internal service endpoint)
GITHUB_MCP_CONNECTION_ID=
AZURE_MCP_CONNECTION_ID=
EVA_MCP_SERVER_URL=
